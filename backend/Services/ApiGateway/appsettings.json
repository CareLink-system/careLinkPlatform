{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "App": {
    "Name": "CareLink Platform API Gateway"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "zN3K9xY8s7FJk2lQvWmP4aR1T6uEoB5cXsfykmdu$&DJUSL9dHfG8JkL2pQ==",
    "Issuer": "careLinkPlatform",
    "Audience": "careLinkPlatformUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/auth" }]
      },
      "patient-route": {
        "ClusterId": "patient-cluster",
        "Match": {
          "Path": "/api/v1/patients/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/patients" }]
      },
      "doctor-route": {
        "ClusterId": "doctor-cluster",
        "Match": {
          "Path": "/api/v1/doctors/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/doctors" }]
      },
      "appointment-route": {
        "ClusterId": "appointment-cluster",
        "Match": {
          "Path": "/api/v1/appointments/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/appointments" }]
      },
      "telemedicine-route": {
        "ClusterId": "telemedicine-cluster",
        "Match": {
          "Path": "/api/v1/telemedicine/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/telemedicine" }]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/payments" }]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/v1/notifications" }]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "https://localhost:5001/"
          }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient": {
            "Address": "https://localhost:5002/"
          }
        }
      },
      "doctor-cluster": {
        "Destinations": {
          "doctor": {
            "Address": "https://localhost:5003/"
          }
        }
      },
      "appointment-cluster": {
        "Destinations": {
          "appointment": {
            "Address": "https://localhost:5004/"
          }
        }
      },
      "telemedicine-cluster": {
        "Destinations": {
          "telemedicine": {
            "Address": "https://localhost:5007/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment": {
            "Address": "https://localhost:5010/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "https://localhost:5008/"
          }
        }
      }
    }
  }
}
