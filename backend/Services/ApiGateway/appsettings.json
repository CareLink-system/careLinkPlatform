            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "https://localhost:5001/"
          }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient": {
            "Address": "https://localhost:5002/"
          }
        }
      },
      "doctor-cluster": {
        "Destinations": {
          "doctor": {
            "Address": "https://localhost:5003/"
          }
        }
      },
      "appointment-cluster": {
        "Destinations": {
