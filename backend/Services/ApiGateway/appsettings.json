{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "App": {
    "Name": "CareLink Platform API Gateway"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "zN3K9xY8s7FJk2lQvWmP4aR1T6uEoB5cXsfykmdu$&DJUSL9dHfG8JkL2pQ==",
    "Issuer": "careLinkPlatform",
    "Audience": "careLinkPlatformUsers"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/Auth/{**catch-all}"
        }
      },
      "patient-route": {
        "ClusterId": "patient-cluster",
        "Match": {
          "Path": "/api/v1/Patients/{**catch-all}"
        }
      },
      "patient-route-base": {
        "ClusterId": "patient-cluster",
        "Match": {
          "Path": "/api/v1/Patients"
        }
      },
      "doctor-route": {
        "ClusterId": "doctor-cluster",
        "Match": {
          "Path": "/api/v1/Doctors/{**catch-all}"
        }
      },
      "doctor-route-base": {
        "ClusterId": "doctor-cluster",
        "Match": {
          "Path": "/api/v1/Doctors"
        }
      },
      "appointment-route": {
        "ClusterId": "appointment-cluster",
        "Match": {
          "Path": "/api/v1/Appointments/{**catch-all}"
        }
      },
      "appointment-route-base": {
        "ClusterId": "appointment-cluster",
        "Match": {
          "Path": "/api/v1/Appointments"
        }
      },
      "telemedicine-route": {
        "ClusterId": "telemedicine-cluster",
        "Match": {
          "Path": "/api/v1/telemedicine/{**catch-all}"
        }
      },
      "telemedicine-route-base": {
        "ClusterId": "telemedicine-cluster",
        "Match": {
          "Path": "/api/v1/telemedicine"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "payment-route-base": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "notification-route-base": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications"
        }
      },
      "symptom-check-route": {
        "ClusterId": "symptom-check-cluster",
        "Match": {
          "Path": "/api/symptom-checker/{**catch-all}"
        }
      },
      "symptom-check-route-base": {
        "ClusterId": "symptom-check-cluster",
        "Match": {
          "Path": "/api/symptom-checker"
        }
      },
      "chatbot-route": {
        "ClusterId": "chatbot-cluster",
        "Match": {
          "Path": "/api/chatbot/{**catch-all}"
        }
      },
      "chatbot-route-base": {
        "ClusterId": "chatbot-cluster",
        "Match": {
          "Path": "/api/chatbot"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "https://localhost:5001/" }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient": { "Address": "https://localhost:5002/" }
        }
      },
      "doctor-cluster": {
        "Destinations": {
          "doctor": { "Address": "https://localhost:5003/" }
        }
      },
      "appointment-cluster": {
        "Destinations": {
          "appointment": { "Address": "https://localhost:5004/" }
        }
      },
      "telemedicine-cluster": {
        "Destinations": {
          "telemedicine": { "Address": "https://localhost:5007/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment": { "Address": "https://localhost:5010/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": { "Address": "https://localhost:5008/" }
        }
      },
      "symptom-check-cluster": {
        "Destinations": {
          "symptom-check": { "Address": "http://localhost:8000/" }
        }
      },
      "chatbot-cluster": {
        "Destinations": {
          "chatbot": { "Address": "http://localhost:8001/" }
        }
      }
    }
  },

  "SwaggerEndpoints": [
    {
      "Name": "Auth Service",
      "Url": "https://localhost:5001/swagger/v1/swagger.json"
    },
    {
      "Name": "Patient Service",
      "Url": "https://localhost:5002/swagger/v1/swagger.json"
