# ChatbotService environment variables
# Copy this file to .env and fill values.

# Required: MongoDB connection string
MONGO_URI=mongodb://localhost:27017

# Optional: DB name (defaults to chatbot)
MONGO_DB=chatbot

# Optional dev fallback when primary Mongo URI is unreachable
MONGO_AUTO_FALLBACK=true
MONGO_FALLBACK_URI=mongodb://localhost:27017

# Required for live Gemini responses
GEMINI_API_KEY=

# Optional: preferred model; service auto-tries backup models
GEMINI_MODEL=gemini-2.0-flash




